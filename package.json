{
  "name": "clean-check",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "node scripts/run-e2e.mjs",
    "e2e:ui": "playwright test --ui",
    "seed:easy-drugs": "node scripts/seed-easy-drugs.mjs",
    "seed:local-medications": "node scripts/seed-local-medications.mjs",
    "seed:prohibited-substances": "node scripts/seed-prohibited-substances.mjs",
    "match:medication-substances": "node scripts/match-medication-substances.mjs",
    "wada:extract": "node scripts/extract-wada-prohibited-list.mjs --check-seed",
    "supabase:check": "node scripts/check-supabase.mjs",
    "supabase:check:write": "node scripts/check-supabase.mjs --write-test",
    "supabase:migrate": "node scripts/apply-supabase-migrations.mjs",
    "supabase:setup": "node scripts/apply-supabase-migrations.mjs && node scripts/seed-local-medications.mjs && node scripts/seed-prohibited-substances.mjs && node scripts/match-medication-substances.mjs && node scripts/check-supabase.mjs --write-test",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run e2e && npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.108.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "14.2.35",
    "pg": "^8.21.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^25.0.1",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.8"
  }
}
