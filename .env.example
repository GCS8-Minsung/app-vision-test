NEXT_PUBLIC_APP_NAME=Clean Check

# Supabase — public browser/server read configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Older Supabase projects can use this instead of NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only batch/admin jobs. Never expose this to the browser.
# Use either SUPABASE_SERVICE_ROLE_KEY for legacy JWT keys or SUPABASE_SECRET_KEY for sb_secret_ keys.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
# Direct Postgres connection URL used only for applying SQL migrations locally.
SUPABASE_DB_URL=

# Google AI API — OCR 이미지 인식에 사용 (https://aistudio.google.com/apikey)
GOOGLE_AI_API_KEY=

# 식약처/공공데이터 의약품 조회용 선택 키
# DRB_EASY_DRUG_API_KEY는 e약은요 배치 적재에 사용합니다.
DRB_EASY_DRUG_API_KEY=
MFDS_API_KEY=
DATA_GO_KR_API_KEY=

# true로 설정한 경우에만 검색 요청 중 공공데이터 실시간 조회를 허용합니다.
ENABLE_REALTIME_MEDICATION_LOOKUP=false
